    {
      "id": 1,
      "interval": "30s",
      "title": "Rolling Sentiment Score",
      "description": "Positive/negative/neutral sentiment averages over 5-second windows",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-atmosphere"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Score",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "avg_positive"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Positive"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_negative"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Negative"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_neutral"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Neutral"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-atmosphere"
          },
          "editorType": "sql",
          "queryType": "table",
          "rawSql": "SELECT * FROM atmosphere.panel_sentiment_timeseries",
          "format": 0
        }
      ]
    },
    {
      "id": 2,
