# RustFS (S3-compatible object storage)
RUSTFS_ROOT_USER=atmosphere
RUSTFS_ROOT_PASSWORD=atmosphere-secret-key

# Postgres (Polaris catalog backing store)
POSTGRES_USER=polaris
POSTGRES_PASSWORD=polaris
POSTGRES_DB=POLARIS

# Polaris catalog
POLARIS_BOOTSTRAP_CREDENTIALS=POLARIS,root,s3cr3t

# Cloudflare Tunnel (leave empty until M7)
TUNNEL_TOKEN=
