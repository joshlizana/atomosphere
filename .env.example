# SeaweedFS (S3-compatible object storage)
# Admin identity is used by the init container for bucket creation and by Spark
# (via the catalog-vended credential path) for warehouse RW. Reader identity is
# used by ClickHouse for read-only access to the warehouse bucket.
SEAWEEDFS_ADMIN_USER=atmosphere
SEAWEEDFS_ADMIN_PASSWORD=atmosphere-secret-key
SEAWEEDFS_READER_USER=atmosphere_reader
SEAWEEDFS_READER_PASSWORD=atmosphere-reader-s3-secret

# Postgres (Polaris catalog backing store)
POSTGRES_USER=polaris
POSTGRES_PASSWORD=polaris
POSTGRES_DB=POLARIS

# Polaris catalog
POLARIS_REALM=POLARIS
POLARIS_ROOT_USER=root
POLARIS_ROOT_PASSWORD=s3cr3t
POLARIS_BOOTSTRAP_CREDENTIALS=${POLARIS_REALM},${POLARIS_ROOT_USER},${POLARIS_ROOT_PASSWORD}

# ClickHouse (serving layer — reads Iceberg via Polaris DataLakeCatalog)
# Grafana logs in as this user (readonly profile)
CLICKHOUSE_READER_USER=atmosphere_reader
CLICKHOUSE_READER_PASSWORD=atmosphere-reader-secret
# init uses this user once for CREATE DATABASE DDL (never touched after)
CLICKHOUSE_ADMIN_USER=atmosphere_admin
CLICKHOUSE_ADMIN_PASSWORD=atmosphere-admin-secret
# Polaris-generated OAuth credentials for the `clickhouse` principal are
# stored in the `polaris-creds` named volume on first init. No .env entry.

# Cloudflare Tunnel (leave empty until M7)
TUNNEL_TOKEN=
