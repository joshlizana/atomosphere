    {
      "id": 1,
      "title": "Rolling Sentiment Score",
      "description": "Positive/negative/neutral sentiment averages over 5-second windows",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity-atmosphere" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Score",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "avg_positive" },
            "properties": [
              { "id": "displayName", "value": "Positive" },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_negative" },
            "properties": [
              { "id": "displayName", "value": "Negative" },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_neutral" },
            "properties": [
              { "id": "displayName", "value": "Neutral" },
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity-atmosphere" },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://query-api:8000/api/mart/sentiment_timeseries",
          "url_options": { "method": "GET" },
          "root_selector": "$.data",
          "columns": [
            { "selector": "window_start", "text": "Time", "type": "timestamp" },
            { "selector": "avg_positive", "text": "avg_positive", "type": "number" },
            { "selector": "avg_negative", "text": "avg_negative", "type": "number" },
            { "selector": "avg_neutral", "text": "avg_neutral", "type": "number" }
          ],
          "parser": "backend"
        }
      ]
    },
    {
      "id": 2,
