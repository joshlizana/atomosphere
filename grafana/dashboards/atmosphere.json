            "excludeByName": {
              "did": true,
              "rkey": true,
              "event_time": true,
              "created_at": true,
              "hashtag_count": true,
              "mention_count": true,
              "link_count": true,
              "sentiment_negative": true,
              "sentiment_neutral": true,
              "sentiment_confidence": true,
              "rank_type": true,
              "content_type": true,
              "primary_lang": true
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              { "field": "sentiment_positive", "desc": true }
            ]
          }
        },
        {
          "id": "limit",
          "options": { "limitField": 5 }
        }
      ],
      "targets": [
